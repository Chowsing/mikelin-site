---
const { items } = Astro.props;
---

<ol class="timeline">
  {
    items.map((item) => (
      <li class="timeline-item">
        <div class="timeline-year">{item.year ?? '未註明'}</div>
        <div class="timeline-card">
          {item.role && <p class="timeline-role">{item.role}</p>}
          <p>{item.description ?? item.text ?? item.fullText}</p>
        </div>
      </li>
    ))
  }
</ol>
