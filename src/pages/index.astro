---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationItem from '../components/PublicationItem.astro';
import SectionTitle from '../components/SectionTitle.astro';
import {
  getAwards,
  getProfile,
  getPublications,
  getResearchProjects,
  getServices,
  groupBy,
} from '../lib/data';
import { withBasePath } from '../lib/site';

const profile = getProfile();
const researchProjectsByCategory = groupBy(getResearchProjects(), (project) => project.category);
const featuredProjectGroups = [
  {
    title: '國科會研究計畫',
    items: (researchProjectsByCategory['國科會研究計畫'] ?? []).filter((project) => project.year >= 2010),
  },
  {
    title: '教育部研究計畫',
    items: (researchProjectsByCategory['教育部研究計畫'] ?? []).filter((project) => project.year >= 2010),
  },
].filter((group) => group.items.length > 0);
const publications = getPublications().slice(0, 6);
const recentServiceCutoffYear = new Date().getFullYear() - 4;
const services = getServices().filter((item) => item.year >= recentServiceCutoffYear);
const awards = getAwards().filter((item) => item.year >= recentServiceCutoffYear);
const heroFocusItems = profile.researchSummary.slice(0, 4);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.nameZh,
  alternateName: profile.nameEn,
  jobTitle: profile.title,
  worksFor: {
    '@type': 'CollegeOrUniversity',
    name: '國立臺南大學',
  },
  alumniOf: profile.education,
  image: Astro.site ? new URL(withBasePath(profile.photo), Astro.site).toString() : withBasePath(profile.photo),
  url: Astro.site ? new URL(withBasePath('/'), Astro.site).toString() : undefined,
};
---

<BaseLayout title="首頁" currentPath="/" structuredData={personSchema}>
  <section class="hero-shell">
    <div class="container hero">
      <section class="hero-copy panel">
        <div class="hero-intro">
          <h1>{profile.nameZh}</h1>
          <p class="hero-title">{profile.title}</p>
          <p class="kicker">{profile.nameEn}</p>
          <p class="hero-education">{profile.education}</p>
          <div class="hero-actions">
            <a class="button" href={withBasePath('/publications')}>學術成果</a>
            <a class="button-secondary" href={withBasePath('/research')}>研究計畫</a>
          </div>
        </div>

        <div class="hero-support-grid">
          <div class="hero-focus hero-focus-panel">
            <strong class="hero-subheading">研究重點</strong>
            <div class="hero-focus-list">
              {heroFocusItems.map((item) => <span class="hero-focus-item">{item}</span>)}
            </div>
          </div>
        </div>
      </section>

      <aside class="hero-card hero-profile-card">
        <img class="profile-photo" src={withBasePath(profile.photo)} alt={`${profile.nameZh} 個人照片`} />
        <div class="hero-meta-section">
          <strong class="hero-subheading">聯絡資訊</strong>
          <div class="meta-grid">
            <div class="meta-item">
              <strong>研究室</strong>
              <span>{profile.office}</span>
            </div>
            <div class="meta-item">
              <strong>分機</strong>
              <span>{profile.extension}</span>
            </div>
            <div class="meta-item">
              <strong>Email</strong>
              <img src={withBasePath(profile.emailImage)} alt="電子郵件聯絡資訊" />
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section feature-band">
    <div class="container summary-grid">
      <article class="content-card">
        <SectionTitle title="研究計畫" />
        <div class="project-home-groups">
          {
            featuredProjectGroups.map((group) => (
              <section class="project-home-group">
                <h3>{group.title}</h3>
                <ul class="plain-list">
                  {group.items.map((project) => (
                    <li>
                      <strong>{project.year}</strong> {project.topic ?? project.title}
                    </li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>
      </article>

      <article class="content-card">
        <SectionTitle title="論文成果" />
        <ol class="publication-list compact-publication-list">
          {publications.map((publication) => <PublicationItem publication={publication} />)}
        </ol>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container summary-grid">
      <article class="content-card">
        <SectionTitle title="服務紀錄" />
        <ul class="plain-list">
          {services.map((item) => <li>{item.fullText}</li>)}
        </ul>
      </article>

      <article class="content-card">
        <SectionTitle title="獲獎榮譽" />
        <ul class="plain-list">
          {awards.map((item) => <li>{item.text}</li>)}
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
